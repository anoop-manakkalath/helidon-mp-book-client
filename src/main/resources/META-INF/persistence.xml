<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
	version="3.1">
    <persistence-unit name="booksPU" transaction-type="JTA">
        <description>A persistence unit for the book project.</description>
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.app.book.model.BookEntity</class>
        <properties>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="jakarta.persistence.transactionType" value="JTA"/>
        </properties>
    </persistence-unit>
</persistence>
